Repository: JSON file access (src/main/java/com/codecrafthub/repository/JsonCourseRepository.java)

private final Path path = Paths.get("data", "courses.json");

private final Object lock = new Object();

public List<Course> loadAll() { synchronized (lock) { if (!Files.exists(path)) return new ArrayList<>(); ObjectMapper mapper = new ObjectMapper(); // support LocalDate mapper.findAndRegisterModules(); try { return mapper.readValue(path.toFile(), new TypeReference<List<Course>>() {}); } catch (IOException e) { throw new RuntimeException("Failed to read courses.json", e); } } }

public void saveAll(List<Course> courses) { synchronized (lock) { ObjectMapper mapper = new ObjectMapper(); mapper.findAndRegisterModules(); mapper.enable(SerializationFeature.INDENT_OUTPUT); try { // write to temp file first for safety Path temp = Paths.get(path.toString() + ".tmp"); mapper.writeValue(temp.toFile(), courses); Files.move(temp, path, StandardCopyOption.REPLACE_EXISTING, StandardCopyOption.ATOMIC_MOVE); } catch (IOException e) { throw new RuntimeException("Failed to write courses.json", e); } } }

public synchronized Long getNextId(List<Course> list) { return list.stream().mapToLong(Course::getId).max().orElse(0L) + 1; }

Basic CRUD helpers (find by id, add, update, delete) can be implemented using loadAll() and saveAll().

Service: CourseService (src/main/java/com/codecrafthub/service/CourseService.java)

@Service
private final JsonCourseRepository repository;
public List<Course> getAll() { return repository.loadAll(); }
public Optional<Course> getById(Long id) { ... search in list ... }
public Course create(Course course) { List<Course> list = repository.loadAll(); Long nextId = repository.getNextId(list); course.setId(nextId); list.add(course); repository.saveAll(list); return course; }
public Course update(Long id, Course updated) { List<Course> list = repository.loadAll(); for (int i = 0; i < list.size(); i++) if (list.get(i).getId().equals(id)) { updated.setId(id); list.set(i, updated); repository.saveAll(list); return updated; } throw new NotFoundException("Course not found"); }
